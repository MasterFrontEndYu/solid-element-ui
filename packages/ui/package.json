  "repository": {
    "type": "git",
    "url": "https://github.com/sanguogege/solid-element-ui"
  },
  "source": "./src/index.tsx",
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
